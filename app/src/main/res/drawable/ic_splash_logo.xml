<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Glowing Background Aura (Subtle mint-violet glow behind the logo) -->
    <path
        android:pathData="M54,20 C72.78,20 88,35.22 88,54 C88,72.78 72.78,88 54,88 C35.22,88 20,72.78 20,54 C20,35.22 35.22,20 54,20 Z"
        android:fillType="nonZero">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="34"
                android:type="radial">
                <item android:color="#1F8A5CBA" android:offset="0.0"/>  <!-- 12% opacity Violet -->
                <item android:color="#0F3B8A75" android:offset="0.6"/>  <!-- 6% opacity Mint -->
                <item android:color="#00000000" android:offset="1.0"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- The Note Card Outline -->
    <path
        android:pathData="M 34 24 L 64 24 L 76 36 L 76 80 A 6 6 0 0 1 70 86 L 34 86 A 6 6 0 0 1 28 80 L 28 30 A 6 6 0 0 1 34 24 Z"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="28"
                android:startY="24"
                android:endX="76"
                android:endY="86"
                android:type="linear">
                <item android:color="#A0AEC0" android:offset="0.0"/>
                <item android:color="#718096" android:offset="1.0"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Folded Flap for the Note Card -->
    <path
        android:pathData="M 64 24 L 64 34 A 2 2 0 0 0 66 36 L 76 36 Z"
        android:fillColor="#718096" />

    <!-- Note lines -->
    <!-- Line 1 -->
    <path
        android:pathData="M 38 44 H 66"
        android:strokeColor="#A0AEC0"
        android:strokeWidth="3"
        android:strokeLineCap="round" />
    <!-- Line 2 -->
    <path
        android:pathData="M 38 54 H 66"
        android:strokeColor="#A0AEC0"
        android:strokeWidth="3"
        android:strokeLineCap="round" />
    <!-- Line 3 -->
    <path
        android:pathData="M 38 64 H 54"
        android:strokeColor="#A0AEC0"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!-- Alarm Clock (overlapping bottom right corner) -->
    <!-- Clock Outer Ring -->
    <path
        android:pathData="M 74 58 A 15 15 0 1 1 73.99 58 Z"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="59"
                android:startY="58"
                android:endX="89"
                android:endY="88"
                android:type="linear">
                <item android:color="#FF8A5CBA" android:offset="0.0"/> <!-- Violet -->
                <item android:color="#FF3B8A75" android:offset="1.0"/> <!-- Mint -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Clock Left Ear (Bell) -->
    <path
        android:pathData="M 60.5 60.5 C 58.5 58.5 57 55.5 59 53.5 C 61 51.5 64 53 66 55"
        android:strokeColor="#FF8A5CBA"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Clock Right Ear (Bell) -->
    <path
        android:pathData="M 87.5 60.5 C 89.5 58.5 91 55.5 89 53.5 C 87 51.5 84 53 82 55"
        android:strokeColor="#FF3B8A75"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Clock Legs -->
    <!-- Left Leg -->
    <path
        android:pathData="M 62 85 L 57 90"
        android:strokeColor="#FF3B8A75"
        android:strokeWidth="3"
        android:strokeLineCap="round" />
    <!-- Right Leg -->
    <path
        android:pathData="M 86 85 L 91 90"
        android:strokeColor="#FF3B8A75"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!-- Clock Hands (pointing to 10:10) -->
    <path
        android:pathData="M 74 66 V 74 H 81"
        android:strokeColor="#FF3B8A75"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Small center pin on the clock -->
    <path
        android:pathData="M 74 74 A 1.5 1.5 0 1 1 73.99 74 Z"
        android:fillColor="#FF8A5CBA" />

</vector>
